<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    tools:context=".ui.DirectionsActivity">

    <!-- Top AppBar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:background="@color/surface_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Chỉ đường"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnNotification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_bell"
            android:contentDescription="Notifications" />
    </LinearLayout>

    <!-- Scrollable main body details to fit both screen heights -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutActionBottom"
        android:layout_below="@+id/topBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Map View frame -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:background="#f0f7f6">

                <!-- Real Map Image loading view -->
                <ImageView
                    android:id="@+id/imgFullMap"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:color/darker_gray" />

                <!-- Location tag bouncing overlay on screen center -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/card_rounded_bg"
                    android:elevation="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="HealthCare Clinic ở đây"
                        android:textColor="@color/on_surface"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <!-- Slide Up Details Sheet Layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-32dp"
                android:background="@drawable/card_rounded_bg"
                android:backgroundTint="@color/surface_container_lowest"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp"
                android:elevation="6dp">

                <!-- Handle bar decorator -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="5dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:background="@color/outline_variant" />

                <!-- Sheet Title Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trung tâm Y tế HealthCare"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Ratings indicators row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="4.9 (120+ Đánh giá)"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="6dp"
                        android:text="•"
                        android:textColor="@color/outline" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang mở cửa"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Detailed Address Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/card_rounded_bg"
                    android:backgroundTint="@color/surface_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="#1A00685f"
                        android:padding="8dp"
                        android:src="@drawable/ic_map"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ĐỊA CHỈ CHI TIẾT"
                            android:textColor="@color/secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="123 Đường Lê Lợi, Phường Bến Thành, Quận 1, Thành phố Hồ Chí Minh"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Opening details & Phone row elements -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <!-- Working hours screen card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/card_rounded_bg"
                        android:backgroundTint="@color/surface_bg"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="GIỜ MỞ CỬA"
                            android:textColor="@color/secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="08:00 - 20:00"
                            android:textColor="@color/on_surface"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Phone working card -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/card_rounded_bg"
                        android:backgroundTint="@color/surface_bg"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_call"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="ĐIỆN THOẠI"
                            android:textColor="@color/secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="1900 1234"
                            android:textColor="@color/on_surface"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Transport / Movement Option Lists layout -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="12dp"
                    android:text="Lựa chọn di chuyển"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Option 1: Car -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/iconCar"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_car"
                            app:tint="@color/secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/iconCar"
                            android:layout_marginStart="12dp"
                            android:text="Ô tô / Taxi"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="~15 phút"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_container" />

                    <!-- Option 2: Bike -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/iconBike"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_bike"
                            app:tint="@color/secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/iconBike"
                            android:layout_marginStart="12dp"
                            android:text="Xe máy"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="~12 phút"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_container" />

                    <!-- Option 3: Bus -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/iconBus"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_bus"
                            app:tint="@color/secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/iconBus"
                            android:layout_marginStart="12dp"
                            android:text="Xe Buýt (Tuyến 01, 03)"
                            android:textColor="@color/on_surface"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="~25 phút"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Bottom action panel with GPS navigation trigger -->
    <LinearLayout
        android:id="@+id/layoutActionBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#CCFFFFFF"
        android:elevation="8dp"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/btnGPSAction"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/button_primary_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:elevation="2dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_near_me"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/txtGPSAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Nhận chỉ đường bằng GPS"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
