<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Giờ bên trái -->
        <LinearLayout
            android:id="@+id/llTime"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvApptTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvApptAmPm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AM"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Thông tin -->
        <LinearLayout
            android:id="@+id/llApptInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/llTime"
            android:layout_toStartOf="@id/tvApptStatus"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvApptPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bệnh nhân"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvApptType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khám tổng quát"
                android:textColor="@android:color/darker_gray"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Badge trạng thái -->
        <TextView
            android:id="@+id/tvApptStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="SẮP TỚI"
            android:textSize="9sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Đường kẻ phân cách -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginHorizontal="16dp" />

</LinearLayout>