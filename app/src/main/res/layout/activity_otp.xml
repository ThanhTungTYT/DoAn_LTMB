<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:padding="20dp">

    <!-- Back Navigation Bar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Go Back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#00685F" />

    <!-- Outer Content block vertical wrapper -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.3">

        <!-- Circular Envelope Frame Mockup -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_circle_icon"
            android:padding="20dp"
            android:src="@drawable/ic_mail_unread"
            app:tint="#00685F" />

        <!-- Title and explanation -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium"
            android:text="Xác thực OTP"
            android:textColor="#0B1C30"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Vui lòng nhập mã 6 chữ số vừa được gửi đến email của bạn:"
            android:textColor="#5C5F61"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvOtpEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="nguyen.an***@email.com"
            android:textColor="#00685F"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Split Grid OTP 6 Fields Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/otpDigit1"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_otp_digit"
                android:gravity="center"
                android:hint="-"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0B1C30"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpDigit2"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_otp_digit"
                android:gravity="center"
                android:hint="-"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0B1C30"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpDigit3"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_otp_digit"
                android:gravity="center"
                android:hint="-"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0B1C30"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpDigit4"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_otp_digit"
                android:gravity="center"
                android:hint="-"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0B1C30"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpDigit5"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_otp_digit"
                android:gravity="center"
                android:hint="-"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0B1C30"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/otpDigit1_6"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_otp_digit"
                android:gravity="center"
                android:hint="-"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#0B1C30"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dynamic Resend Timer Counter -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Gửi lại mã sau 00:59"
            android:textColor="#5C5F61"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="Gửi lại mã ngay"
            android:textColor="#00685F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Primary Confirm Action button -->
        <Button
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_button_primary"
            android:fontFamily="sans-serif-medium"
            android:text="Xác nhận"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="textEnd"
            app:iconTint="#FFFFFF" />

        <!-- Optional Support link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn gặp vấn đề? "
                android:textColor="#5C5F61"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSupportLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Liên hệ hỗ trợ"
                android:textColor="#316BF3"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>