<?xml version="1.0" encoding="utf-8"?>
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F6F8">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:elevation="0dp">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbarBooking"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIcon="@drawable/ic_arrow_back">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xác nhận lịch"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"/>

            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="100dp"
            android:clipToPadding="false"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_circle_icon_light"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="🏥 Khám Tổng Quát"
                    android:textColor="#0A7067"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvMainPackageName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Xét nghiệm máu +\nKhám sức khỏe lâm\nsàng"
                    android:textColor="#0F2942"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.1"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvPackagePrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 VNĐ"
                    android:textColor="#0A7067"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bước 1/3: Chọn thời gian"
                    android:textColor="#999999"
                    android:textSize="11sp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="16dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋 Giới thiệu gói"
                            android:textColor="#0A7067"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tvIntroContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Gói khám sức khỏe tổng quát cơ bản bao gồm các xét nghiệm máu cần thiết và thăm khám lâm sàng ban đầu để đánh giá tình trạng sức khỏe chung, phát hiện sớm các nguy cơ tiềm ẩn."
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📑 Quy trình thực hiện"
                            android:textColor="#0A7067"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1. Lấy mẫu máu\n   Thực hiện vào buổi sáng, nhịn ăn trước khi lấy mẫu.\n\n2. Đo sinh hiệu\n   Kiểm tra huyết áp, nhịp tim, chiều cao, cân nặng.\n\n3. Khám lâm sàng\n   Bác sĩ tổng quát tư vấn và kết luận dựa trên kết quả."
                            android:textColor="#555555"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.2"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📅 Chọn lịch hẹn"
                            android:textColor="#0F2942"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="12dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvCalendarHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            tools:listitem="@layout/item_calendar_date" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvTimeSlotsGrid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                            app:spanCount="3"
                            tools:listitem="@layout/item_time_slot"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👤 Thông tin bệnh nhân"
                                android:textColor="#0F2942"
                                android:textStyle="bold"
                                android:textSize="14sp"/>
                            <TextView
                                android:id="@+id/tvChangePatient"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Thay đổi"
                                android:textColor="#0A7067"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8F9FA"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/bg_circle_icon_light"
                                app:tint="#0A7067"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">
                                <TextView
                                    android:id="@+id/tvPatientName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nguyễn Văn A"
                                    android:textColor="#1A1A1A"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:id="@+id/tvPatientSubInfo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nam • 35 tuổi • 0901234567"
                                    android:textColor="#777777"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <Button
                android:id="@+id/btnConfirmBooking"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:text="Xác nhận đăng ký"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:background="@drawable/bg_button_primary"/>

        </FrameLayout>
    </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>