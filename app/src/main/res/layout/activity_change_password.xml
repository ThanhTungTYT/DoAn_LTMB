<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:orientation="vertical">

    <!-- Top bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="1dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/btnBackChangePw"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerInParent="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Quay lại"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#0B1C30" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/btnBackChangePw"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Đổi mật khẩu"
                    android:textColor="#0B1C30"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mật khẩu hiện tại"
                android:textColor="#0B1C30"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field">

                <EditText
                    android:id="@+id/edtOldPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Nhập mật khẩu hiện tại"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="48dp"
                    android:textColor="#0B1C30"
                    android:textColorHint="#94A3B8"
                    android:textSize="15sp" />

                <ImageButton
                    android:id="@+id/btnToggleOld"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Ẩn/hiện mật khẩu"
                    android:src="@drawable/ic_visibility"
                    app:tint="#5C5F61" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Mật khẩu mới"
                android:textColor="#0B1C30"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field">

                <EditText
                    android:id="@+id/edtNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Ít nhất 6 ký tự"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="48dp"
                    android:textColor="#0B1C30"
                    android:textColorHint="#94A3B8"
                    android:textSize="15sp" />

                <ImageButton
                    android:id="@+id/btnToggleNew"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Ẩn/hiện mật khẩu"
                    android:src="@drawable/ic_visibility"
                    app:tint="#5C5F61" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Xác nhận mật khẩu mới"
                android:textColor="#0B1C30"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field">

                <EditText
                    android:id="@+id/edtConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Nhập lại mật khẩu mới"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="48dp"
                    android:textColor="#0B1C30"
                    android:textColorHint="#94A3B8"
                    android:textSize="15sp" />

                <ImageButton
                    android:id="@+id/btnToggleConfirm"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Ẩn/hiện mật khẩu"
                    android:src="@drawable/ic_visibility"
                    app:tint="#5C5F61" />
            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:text="Đổi mật khẩu"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#00685F"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
