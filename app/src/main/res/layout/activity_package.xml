<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- THANH TIÊU ĐỀ (ActionBar/Toolbar) -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarPackages"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu"
                android:layout_gravity="start"/> <!-- Icon menu bên trái -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HealthCare"
                android:textColor="#0A7067"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center"/>
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_notification"
                android:layout_gravity="end"
                android:layout_marginRight="16dp"/> <!-- Icon chuông bên phải -->
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- THÂN CUỘN CHỨA NỘI DUNG -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="60dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. BANNER XANH NGỌC -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#0A7067"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvBannerTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khám sức khỏe tổng quát"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvBannerTitle"
                        android:text="Chăm sóc chủ động cho bản thân và gia đình với các gói khám chuyên sâu."
                        android:textColor="#E0F2F1"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.2"/>
                    <!-- Bạn có thể thêm một ImageView minh họa nhỏ ở góc phải nếu cần -->
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- 2. THANH CHỌN TAB (FILTER BUTTONS) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Tab Tất cả (Được chọn mặc định) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tab_selected"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Tất cả"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginRight="8dp"/>

                <!-- Tab Xét nghiệm -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tab_unselected"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Xét nghiệm"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:layout_marginRight="8dp"/>

                <!-- Tab Chụp CT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tab_unselected"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Chụp CT"
                    android:textColor="#555555"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- 3. DANH SÁCH GÓI KHÁM (Dùng RecyclerView để đổ data linh hoạt) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMedicalPackages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_medical_package"
                android:layout_marginBottom="24dp"/>

            <!-- 4. KHỐI CAM KẾT: TẠI SAO CHỌN CHÚNG TÔI? -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingVertical="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAI SAO CHỌN CHÚNG TÔI?"
                    android:textColor="#0B4A75"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Tiêu chí 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_verified"
                            app:tint="#0A7067"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bác sĩ chuyên khoa"
                            android:textColor="#555555"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Tiêu chí 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_star"
                            app:tint="#0A7067"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thiết bị hiện đại"
                            android:textColor="#555555"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Tiêu chí 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_tune"
                            app:tint="#0A7067"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kết quả nhanh"
                            android:textColor="#555555"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>