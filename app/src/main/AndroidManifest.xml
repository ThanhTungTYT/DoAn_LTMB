<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="HealthCare"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HealthCareApp">

        <!-- ===== Màn hình khởi chạy: Trang chủ ===== -->
        <!-- Tạm để Home làm launcher. Khi dat làm xong LoginActivity thì đổi
             launcher sang Login và bỏ intent-filter ở đây. -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== Luồng đặt lịch khám bác sĩ cá nhân (Bao) ===== -->
        <activity android:name=".ui.DoctorDetailActivity" android:exported="false" />
        <activity android:name=".ui.PaymentActivity" android:exported="false" />
        <activity android:name=".ui.HistoryActivity" android:exported="false" />

        <!-- ===== Gói khám / Tóm tắt khám (phu) ===== -->
        <activity android:name=".ui.PackageActivity" android:exported="false" />
        <activity android:name=".ui.AppointmentBookingActivity" android:exported="false" />
        <activity android:name=".ui.MedicalSummaryActivity" android:exported="false" />

        <!-- ===== Tìm bác sĩ / Bản đồ chỉ đường (Sinh) ===== -->
        <activity android:name=".ui.DoctorSearchActivity" android:exported="false" />
        <activity android:name=".ui.DirectionsActivity" android:exported="false" />

        <!-- ===== Vai trò bác sĩ / quản trị (tung) ===== -->
        <activity android:name=".ui.adminRoleDoctor.AdminOverviewActivity" android:exported="false" />
        <activity android:name=".ui.adminRoleDoctor.DoctorScheduleActivity" android:exported="false" />
        <activity android:name=".ui.adminRoleDoctor.MyScheduleActivity" android:exported="false" />

        <!-- ===== CHƯA CÓ CODE JAVA (dat mới làm layout) - thêm lại khi xong =====
        <activity android:name=".LoginActivity" android:exported="true" />
        <activity android:name=".RegisterActivity" android:exported="false" />
        <activity android:name=".OtpActivity" android:exported="false" />
        -->

    </application>
</manifest>
